# SilentBid Frontend — Sepolia Configuration

# Network: Sepolia (default). Set to "anvil" for local dev with Anvil.
# NEXT_PUBLIC_NETWORK=anvil

# Network (default: base-sepolia)
# NEXT_PUBLIC_NETWORK=base-sepolia

# RPC URLs
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Contract Addresses (Base Sepolia)
NEXT_PUBLIC_USDC_ADDRESS=0xA8269A6Dc3f9AE5936A930e5F8Fa9B17937feE94
NEXT_PUBLIC_CUSDC_ADDRESS=0xa1585b1792ed34754BE126584BBDa5CB7e15bA3d
NEXT_PUBLIC_AUCTION_ADDRESS=0xbf6b4Dd1E1498f575ffC3722E4350F9C51abEa78
NEXT_PUBLIC_UNWRAPPER_ADDRESS=0xf43F4FC18BaCEFE1C96e4FA6bdc8585FBAEd4Cf7
NEXT_PUBLIC_TREASURY_ADDRESS=0x1D1494b3a858Ed8b37B362eA6895665FfC71D11B

# Etherscan API key (optional; for contract verification scripts)
# ETHERSCAN_API_KEY=your_etherscan_api_key
